[Unit]
Description=Cacophony Project Python Thermal Medium Power
DefaultDependencies=no
Wants=network-pre.target
Before=network-pre.target
After=local-fs.target systemd-modules-load.service


[Service]
Type=simple
ExecStart=/home/pi/.venv/classifier/bin/python3  /home/pi/MediumPower/src/mediumpower.py
Restart=always
RestartSec=3s

[Install]
WantedBy=multi-user.target
